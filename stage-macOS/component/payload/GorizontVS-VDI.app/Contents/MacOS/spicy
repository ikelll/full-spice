#!/bin/bash
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
APP="$(cd "$HERE/.." && pwd)"
FW="$APP/Frameworks"
RES="$APP/Resources"
SPICE="$RES/spice"
BREW="$RES/brew"

# Бинарники
export PATH="$BREW/bin:$SPICE/bin:/usr/bin:/bin"

# Главное: где искать dylib внутри bundle
export DYLD_LIBRARY_PATH="$FW:$BREW/lib:$SPICE/lib"

# GIR / typelibs
export GI_TYPELIB_PATH="$BREW/lib/girepository-1.0:$SPICE/lib/girepository-1.0"

# Data dirs (иконки, схемы, desktop-файлы и т.п.)
export XDG_DATA_DIRS="$BREW/share:$SPICE/share:/usr/share"

# GSettings schemas (очень часто нужно для GTK/GLib)
export GSETTINGS_SCHEMA_DIR="$BREW/share/glib-2.0/schemas:$SPICE/share/glib-2.0/schemas"

# GIO modules (иногда нужно, если glib собран с модулями)
export GIO_MODULE_DIR="$BREW/lib/gio/modules"

# GStreamer: использовать ТОЛЬКО плагины из bundle
export GST_PLUGIN_SYSTEM_PATH=""
export GST_PLUGIN_PATH="$BREW/lib/gstreamer-1.0"
export GST_PLUGIN_SCANNER="$BREW/libexec/gstreamer-1.0/gst-plugin-scanner"
export GST_REGISTRY="${HOME}/Library/Caches/spicy-gst-registry.bin"

# Pixbuf loaders
export GDK_PIXBUF_MODULEDIR="$BREW/lib/gdk-pixbuf-2.0/2.10.0/loaders"
export GDK_PIXBUF_MODULE_FILE="$BREW/lib/gdk-pixbuf-2.0/loaders.cache"

exec "$HERE/spicy.real" "$@"

